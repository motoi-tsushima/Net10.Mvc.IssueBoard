@model IEnumerable<Net10.Mvc.IssueBoard.Models.ViewModels.IssueListViewModel>

@{
    ViewData["Title"] = "課題一覧";
}

<h1>課題一覧</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">課題登録</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>記入者氏名</th>
            <th>登録日時</th>
            <th>カテゴリ名</th>
            <th>課題タイトル</th>
            <th>現在の状況</th>
            <th>解決担当者名</th>
            <th>最終結果日時</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.AuthorName</td>
            <td>@item.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
            <td>@(item.Category ?? "")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
            </td>
            <td>@item.Status.GetDisplayName()</td>
            <td>@(item.ResolverName ?? "")</td>
            <td>@(item.ResolvedAt?.ToString("yyyy/MM/dd HH:mm") ?? "")</td>
        </tr>
}
    </tbody>
</table>
