@model Net10.Mvc.IssueBoard.Models.ViewModels.IssueDetailViewModel

@{
    ViewData["Title"] = "課題内容表示";
}

<h1>課題内容表示</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">記入者氏名</dt>
            <dd class="col-sm-9">@Model.AuthorName</dd>

            <dt class="col-sm-3">登録日時</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm:ss")</dd>

            <dt class="col-sm-3">カテゴリ名</dt>
            <dd class="col-sm-9">@(Model.Category ?? "-")</dd>

            <dt class="col-sm-3">課題タイトル</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">課題の文面</dt>
            <dd class="col-sm-9" style="white-space: pre-wrap;">@Model.Description</dd>

            <dt class="col-sm-3">現在の状況</dt>
            <dd class="col-sm-9">@Model.Status.GetDisplayName()</dd>

            <dt class="col-sm-3">解決の文面</dt>
            <dd class="col-sm-9" style="white-space: pre-wrap;">@(Model.Resolution ?? "")</dd>

            <dt class="col-sm-3">解決担当者名</dt>
            <dd class="col-sm-9">@(Model.ResolverName ?? "")</dd>

            <dt class="col-sm-3">最終結果日時</dt>
            <dd class="col-sm-9">@(Model.ResolvedAt?.ToString("yyyy/MM/dd HH:mm:ss") ?? "")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">編集</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">削除</a>
    <a asp-action="Index" class="btn btn-secondary">戻る</a>
</div>
